# Database
DATABASE_URL=postgresql+asyncpg://cmm_user:your_password@localhost:5432/community_mind_mirror
DATABASE_URL_SYNC=postgresql://cmm_user:your_password@localhost:5432/community_mind_mirror

# Redis
REDIS_URL=redis://localhost:6379/0

# YouTube Data API v3
YOUTUBE_API_KEY=

# Azure OpenAI (or any OpenAI-compatible endpoint)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_DEPLOYMENT_MINI=
AZURE_OPENAI_API_VERSION=2024-06-01

# GitHub (for repo/star scraping)
GITHUB_TOKEN=

# Product Hunt
PH_ACCESS_TOKEN=

# Stack Overflow
SO_API_KEY=

# Email notifications (Resend)
RESEND_API_KEY=
NOTIFY_EMAIL=
FROM_EMAIL=onboarding@resend.dev

# Scraper settings
SCRAPER_LOG_LEVEL=INFO
REDDIT_REQUEST_DELAY=5.0
HN_REQUEST_DELAY=0.1

# Frontend (set in dashboard/.env)
# VITE_API_URL=/api
